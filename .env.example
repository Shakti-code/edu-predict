# ─────────────────────────────────────────────────────────────────────────────
# EduPredict — Environment Variables Template
# Copy this file to .env and fill in real values. NEVER commit .env to git.
# ─────────────────────────────────────────────────────────────────────────────

# Django Core
# Generate a new key with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=your-very-secret-key-here

# Set to False in production
DEBUG=False

# Comma-separated list of allowed hostnames (no spaces)
# Example: ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com
ALLOWED_HOSTS=localhost,127.0.0.1

# ─── Database ────────────────────────────────────────────────────────────────
# PostgreSQL (recommended for production)
# Format: postgres://USER:PASSWORD@HOST:PORT/DBNAME
# DATABASE_URL=postgres://postgres:password@localhost:5432/edupredict

# Leave blank to use SQLite (development only)
DATABASE_URL=

# ─── Email (SMTP) ────────────────────────────────────────────────────────────
# Leave EMAIL_HOST_USER blank to use console email backend (development only)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@edupredict.com

# ─── Security (set in production) ────────────────────────────────────────────
# Uncomment and set to True when running behind HTTPS
# SECURE_SSL_REDIRECT=True
